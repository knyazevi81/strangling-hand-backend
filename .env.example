# ── Database ───────────────────────────────────────────────────────────────────
DB_NAME=vpndb
DB_USER=postgres
DB_PASS=postgres
DB_HOST=localhost
DB_PORT=5432

# ── JWT ────────────────────────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-to-a-256-bit-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── CORS ───────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8080"]

# ── Project ────────────────────────────────────────────────────────────────────
PROJECT_TITLE=vpn-access-service
BASE_PATH=/vpn-service/

# ── Logging ────────────────────────────────────────────────────────────────────
LOG_LEVEL=20
GRAYLOG_ENABLED=false
